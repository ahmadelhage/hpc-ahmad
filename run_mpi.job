#!/bin/bash

#SBATCH --job-name=hpc          # Job name
#SBATCH --output=job_%j.out     # Output file (%j = SLURM job ID)
#SBATCH --error=job_%j.err      # Error file
#SBATCH --nodes=8               # Number of nodes (modifiy for MPI)
#SBATCH --ntasks-per-node=8     # Number of tasks per node
#SBATCH --cpus-per-task=1       # Number of threads per task (modify for multithreading)
#SBATCH --gres=gpu:A4000-Ada:1  # Number of GPUs per node
#SBATCH --time=00:15:00         # Time limit (HH:MM:SS). Do not exceed 15 minutes! Changed temporarily for testing during off peak hours.
#SBATCH --nice=100              # Job priority (allow higher priority jobs first)

# Set PROG to the name of your implementation's binary (e.g., cgc_mpi)
PROG=cgc_mpi
DATA=/var/scratch/bwn200/HPC_data/spring_data_xl.npy
LABELS=/var/scratch/bwn200/HPC_data/spring_labels_xl_3x20.txt
OUT=labels_${SLURM_JOB_ID}.txt

# Load required modules
module load openmpi4/4.1.6
module load cuda12.6/toolkit/12.6

# Set environment variables if needed (e.g., OMP_NUM_THREADS when using OpenMP)
#export OMP_NUM_THREADS=${SLURM_CPUS_PER_TASK}

# Run the binary with arguments
mpirun -np ${SLURM_NTASKS} ./${PROG} ${DATA} ${LABELS} -o ${OUT}